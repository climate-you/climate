{
  "version": "0.1",
  "era5_daily_t2m": {
    "id": "era5_daily_t2m",
    "title": "ERA5 daily 2m temperature",
    "grid_id": "global_0p25",
    "tile_size": 64,
    "source": {
      "type": "cds",
      "dataset": "derived-era5-single-levels-daily-statistics",
      "variable": "2m_temperature",
      "postprocess": [{ "fn": "k_to_c" }],
      "time_range": { "start_year": 1979, "end_year": 2025 },
      "block_years": 1,
      "block_months": 1,
      "batch_tiles": 24
    }
  },
  "era5_daily_t2m_max": {
    "id": "era5_daily_t2m_max",
    "title": "ERA5 daily 2m temperature (daily maximum)",
    "grid_id": "global_0p25",
    "tile_size": 64,
    "source": {
      "type": "cds",
      "dataset": "derived-era5-single-levels-daily-statistics",
      "variable": "2m_temperature",
      "postprocess": [{ "fn": "k_to_c" }],
      "time_range": { "start_year": 1979, "end_year": 2025 },
      "block_years": 1,
      "block_months": 1,
      "batch_tiles": 24,
      "params": {
        "daily_statistic": "daily_maximum"
      }
    }
  },
  "era5_daily_t2m_min": {
    "id": "era5_daily_t2m_min",
    "title": "ERA5 daily 2m temperature (daily minimum)",
    "grid_id": "global_0p25",
    "tile_size": 64,
    "source": {
      "type": "cds",
      "dataset": "derived-era5-single-levels-daily-statistics",
      "variable": "2m_temperature",
      "postprocess": [{ "fn": "k_to_c" }],
      "time_range": { "start_year": 1979, "end_year": 2025 },
      "block_years": 1,
      "block_months": 1,
      "batch_tiles": 24,
      "params": {
        "daily_statistic": "daily_minimum"
      }
    }
  },
  "era5_daily_tp": {
    "id": "era5_daily_tp",
    "title": "ERA5 daily total precipitation",
    "grid_id": "global_0p25",
    "tile_size": 64,
    "source": {
      "type": "cds",
      "dataset": "derived-era5-single-levels-daily-statistics",
      "variable": "total_precipitation",
      "postprocess": [{ "fn": "m_to_mm" }, { "fn": "scale", "params": { "factor": 24 } }],
      "time_range": { "start_year": 1979, "end_year": 2025 },
      "block_years": 1,
      "block_months": 1,
      "batch_tiles": 24
    }
  },
  "era5_monthly_t2m": {
    "id": "era5_monthly_t2m",
    "title": "ERA5 monthly 2m temperature",
    "grid_id": "global_0p25",
    "tile_size": 64,
    "source": {
      "type": "cds",
      "dataset": "reanalysis-era5-single-levels-monthly-means",
      "variable": "2m_temperature",
      "postprocess": [{ "fn": "k_to_c" }],
      "time_range": { "start_year": 1979, "end_year": 2025 },
      "block_years": 47,
      "batch_tiles": 4
    }
  },
  "cmip6_historical_tas_monthly_5model_mean": {
    "id": "cmip6_historical_tas_monthly_5model_mean",
    "title": "CMIP6 historical monthly near-surface air temperature (5-model blend)",
    "grid_id": "global_0p25",
    "tile_size": 64,
    "source": {
      "type": "cds",
      "dataset": "projections-cmip6",
      "variable": "near_surface_air_temperature",
      "postprocess": [{ "fn": "k_to_c" }],
      "time_range": { "start_year": 1850, "end_year": 2014 },
      "block_years": 51,
      "batch_tiles": 4,
      "params": {
        "cds_cadence": "monthly",
        "regrid_to_metric_grid": true,
        "regrid_method": "bilinear",
        "cache_tag": "5model_mean",
        "request_template": {
          "temporal_resolution": "monthly",
          "experiment": "historical",
          "format": "netcdf",
          "model": [
            "access_cm2",
            "canesm5",
            "mpi_esm1_2_lr",
            "ipsl_cm6a_lr",
            "ukesm1_0_ll"
          ]
        },
        "variable_field": "variable",
        "year_field": "year",
        "month_field": "month"
      }
    }
  },
  "era5_daily_tp": {
    "id": "era5_daily_tp",
    "title": "ERA5 daily total precipitation",
    "grid_id": "global_0p25",
    "tile_size": 64,
    "source": {
      "type": "cds",
      "dataset": "derived-era5-single-levels-daily-statistics",
      "variable": "total_precipitation",
      "postprocess": [
        { "fn": "m_to_mm" },
        { "fn": "scale", "params": { "factor": 24 } }
      ],
      "time_range": { "start_year": 1979, "end_year": 2025 },
      "block_years": 1,
      "block_months": 1,
      "batch_tiles": 24
    }
  },
  "oisst_sst_v21_daily": {
    "id": "oisst_sst_v21_daily",
    "title": "OISST v2.1 daily SST",
    "grid_id": "global_0p25",
    "tile_size": 64,
    "source": {
      "type": "erddap",
      "dataset_key": "oisst_sst_v21_daily",
      "time_range": { "start_year": 1982, "end_year": 2025 },
      "block_years": 1,
      "batch_tiles": 4
    }
  },
  "crw_dhw_daily": {
    "id": "crw_dhw_daily",
    "title": "NOAA Coral Reef Watch daily Degree Heating Week",
    "grid_id": "global_0p05",
    "tile_size": 64,
    "source": {
      "type": "erddap",
      "dataset_key": "crw_dhw_daily",
      "time_range": { "start_year": 1985, "end_year": 2025 },
      "block_years": 1,
      "batch_tiles": 2,
      "mask_file": "data/masks/crw_dhw_daily_global_0p05_mask.npz"
    }
  }
}
