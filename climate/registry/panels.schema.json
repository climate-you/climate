{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Climate Panel Registry",
  "description": "Schema for registry/panels.json defining panels/graphs/series.",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "panels": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9_]*$": { "$ref": "#/$defs/panel" }
      },
      "additionalProperties": false
    }
  },
  "required": ["panels"],
  "additionalProperties": false,
  "$defs": {
    "panel": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "score_map_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "graphs": {
          "type": "array",
          "items": { "$ref": "#/$defs/graph" },
          "minItems": 1
        }
      },
      "required": ["title", "score_map_id", "graphs"],
      "additionalProperties": false
    },
    "graph": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "title": { "type": "string" },
        "ui": { "$ref": "#/$defs/graph_ui" },
        "caption": { "$ref": "#/$defs/caption" },
        "source": { "type": "string" },
        "x_axis_label": { "type": "string" },
        "y_axis_label": { "type": "string" },
        "time_range": { "$ref": "#/$defs/time_range" },
        "animation": { "$ref": "#/$defs/graph_animation" },
        "series": {
          "type": "array",
          "items": { "$ref": "#/$defs/series" },
          "minItems": 1
        }
      },
      "required": ["id", "title", "series"],
      "additionalProperties": false
    },
    "time_range": {
      "type": "object",
      "properties": {
        "start": { "$ref": "#/$defs/time_value" },
        "end": { "$ref": "#/$defs/time_value" },
        "last": { "$ref": "#/$defs/time_duration" },
        "offset": { "$ref": "#/$defs/time_duration" }
      },
      "additionalProperties": false,
      "anyOf": [
        { "required": ["start"] },
        { "required": ["end"] },
        { "required": ["start", "end"] },
        { "required": ["last"] }
      ]
    },
    "time_value": {
      "type": ["number", "string"]
    },
    "time_duration": {
      "type": "object",
      "properties": {
        "value": { "type": "integer", "minimum": 0 },
        "unit": { "type": "string", "enum": ["points", "days", "months", "years"] }
      },
      "required": ["value", "unit"],
      "additionalProperties": false
    },
    "graph_animation": {
      "type": "object",
      "properties": {
        "autoplay": { "type": "boolean", "default": true },
        "loop": { "type": "boolean", "default": true },
        "step_duration_ms": { "type": "integer", "minimum": 200, "default": 2600 },
        "transition_ms": { "type": "integer", "minimum": 100, "default": 900 },
        "steps": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/graph_animation_step" }
        }
      },
      "required": ["steps"],
      "additionalProperties": false
    },
    "graph_animation_step": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "title": { "type": "string" },
        "time_range": { "$ref": "#/$defs/time_range" },
        "series_keys": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
        }
      },
      "required": ["id"],
      "additionalProperties": false
    },
    "series": {
      "type": "object",
      "properties": {
        "key": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "metric": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "label": { "type": "string" },
        "shortLabel": { "type": "string" },
        "ui": { "$ref": "#/$defs/series_ui" },
        "unit": { "type": "string" },
        "transform": { "$ref": "#/$defs/transform" },
        "style": { "$ref": "#/$defs/series_style" },
        "annotations": {
          "type": "array",
          "items": { "$ref": "#/$defs/annotation" }
        }
      },
      "required": ["metric", "label"],
      "additionalProperties": false
    },
    "annotation": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["min", "max", "range", "note"] },
        "value": { "type": ["number", "string"] },
        "value2": { "type": ["number", "string"] },
        "label": { "type": "string" }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "transform": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["fn"],
          "properties": {
            "fn": { "type": "string" },
            "params": { "type": "object", "additionalProperties": true, "default": {} }
          },
          "additionalProperties": false
        }
      ]
    },
    "caption": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "text"],
          "properties": {
            "type": { "const": "static" },
            "text": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "fn"],
          "properties": {
            "type": { "const": "fn" },
            "fn": { "type": "string" },
            "params": { "type": "object", "additionalProperties": true, "default": {} }
          },
          "additionalProperties": false
        }
      ]
    },
    "graph_ui": {
      "type": "object",
      "properties": {
        "info_text": { "type": "string" },
        "chart_mode": {
          "type": "string",
          "enum": ["temperature_line", "hot_days_combo", "stacked_bar"]
        },
        "axis_title_mode": {
          "type": "string",
          "enum": ["year", "date"]
        }
      },
      "additionalProperties": false
    },
    "series_ui": {
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["raw", "mean", "trend", "category"]
        }
      },
      "additionalProperties": false
    },
    "series_style": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["line", "bar"] },
        "color": {
          "type": "string",
          "pattern": "^(?:#(?:[0-9a-fA-F]{3}|[0-9a-fA-F]{6})|rgb\\(\\s*(?:[01]?\\d?\\d|2[0-4]\\d|25[0-5])\\s*,\\s*(?:[01]?\\d?\\d|2[0-4]\\d|25[0-5])\\s*,\\s*(?:[01]?\\d?\\d|2[0-4]\\d|25[0-5])\\s*\\)|rgba\\(\\s*(?:[01]?\\d?\\d|2[0-4]\\d|25[0-5])\\s*,\\s*(?:[01]?\\d?\\d|2[0-4]\\d|25[0-5])\\s*,\\s*(?:[01]?\\d?\\d|2[0-4]\\d|25[0-5])\\s*,\\s*(?:0|1|0?\\.\\d+)\\s*\\))$"
        },
        "stack": { "type": "string", "minLength": 1 }
      },
      "required": ["type"],
      "additionalProperties": false
    }
  }
}
