{
  "version": "0.1",
  "t2m_yearly_mean_c": {
    "id": "t2m_yearly_mean_c",
    "title": "2m temperature yearly mean",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "grid_id": "global_0p25",
    "time_axis": "yearly",
    "source": {
      "type": "cds",
      "dataset": "reanalysis-era5-single-levels-monthly-means",
      "variable": "2m_temperature",
      "agg": "annual_mean_from_monthly",
      "postprocess": [{ "fn": "k_to_c" }]
    },
    "storage": {
      "tiled": true,
      "tile_size": 64,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "t2m_yearly_5y_mean_c": {
    "id": "t2m_yearly_5y_mean_c",
    "title": "2m temperature 5y rolling mean",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "grid_id": "global_0p25",
    "time_axis": "yearly",
    "source": {
      "type": "derived",
      "inputs": ["t2m_yearly_mean_c"],
      "steps": [
        { "fn": "rolling_mean", "params": { "window": 5, "centered": true } }
      ]
    },
    "materialize": "on_api"
  },
  "t2m_hotdays_per_year": {
    "id": "t2m_hotdays_per_year",
    "title": "T2m hot days per year",
    "unit": "days",
    "dtype": "float32",
    "missing": "nan",
    "grid_id": "global_0p25",
    "time_axis": "yearly",
    "source": {
      "type": "cds",
      "dataset": "derived-era5-single-levels-daily-statistics",
      "variable": "2m_temperature",
      "time_range": { "start_year": 1979, "end_year": 2025 },
      "agg": "hot_days_per_year",
      "params": {
        "baseline_years": 10,
        "percentile": 90,
        "daily_statistic": "daily_mean",
        "block_months": 1
      },
      "postprocess": [{ "fn": "k_to_c" }]
    },
    "storage": {
      "tiled": true,
      "tile_size": 64,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "sst_yearly_mean_c": {
    "id": "sst_yearly_mean_c",
    "title": "SST yearly mean",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "grid_id": "global_0p25",
    "time_axis": "yearly",
    "source": {
      "type": "erddap",
      "dataset_key": "oisst_sst_v21_daily",
      "agg": "annual_mean_from_daily",
      "block_years": 1,
      "time_range": { "start_year": 1982, "end_year": 2025 }
    },
    "storage": {
      "tiled": true,
      "tile_size": 64,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "sst_hotdays_per_year": {
    "id": "sst_hotdays_per_year",
    "title": "SST hot days per year",
    "unit": "days",
    "dtype": "float32",
    "missing": "nan",
    "grid_id": "global_0p25",
    "time_axis": "yearly",
    "source": {
      "type": "erddap",
      "dataset_key": "oisst_sst_v21_daily",
      "agg": "hot_days_per_year",
      "params": { "baseline_years": 10, "percentile": 90 },
      "block_years": 1,
      "time_range": { "start_year": 1982, "end_year": 2025 }
    },
    "storage": {
      "tiled": true,
      "tile_size": 64,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "dummy1_yearly_mean_c": {
    "id": "dummy1_yearly_mean_c",
    "title": "Dummy metric (0.25° grid)",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "grid_id": "global_0p25",
    "time_axis": "yearly",
    "source": {
      "type": "derived",
      "inputs": ["t2m_yearly_mean_c"],
      "steps": ["identity"]
    },
    "storage": {
      "tiled": true,
      "tile_size": 64,
      "compression": { "codec": "none" }
    }
  },
  "dummy2_yearly_mean_c": {
    "id": "dummy2_yearly_mean_c",
    "title": "Dummy metric (0.05° grid)",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "grid_id": "global_0p05",
    "time_axis": "yearly",
    "source": {
      "type": "derived",
      "inputs": ["t2m_yearly_mean_c"],
      "steps": ["identity"]
    },
    "storage": {
      "tiled": true,
      "tile_size": 64,
      "compression": { "codec": "none" }
    }
  }
}
