# Climate web environment variables (copy to /etc/climate/web.env)

NODE_ENV=production
SITE_URL=https://example.com
NEXT_PUBLIC_CLIMATE_API_BASE=https://example.com
NEXT_PUBLIC_MAP_ASSET_BASE=https://example.com
NEXT_PUBLIC_RELEASE=latest
# Keep disabled in normal deployments. Enable only for local demo recording.
NEXT_PUBLIC_ENABLE_DEMO_VIDEO=0
PORT=3000
