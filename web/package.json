{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:fast": "next dev --turbo --disable-source-maps",
    "dev:fast:lan": "next dev --turbo --disable-source-maps --hostname 0.0.0.0 --port 3000",
    "dev:webpack-fast": "next dev --webpack --disable-source-maps",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"src/**/*.{ts,tsx,mjs,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,mjs,js,json}\"",
    "test:unit": "node --test src/lib/*.test.mjs",
    "postinstall": "patch-package && node scripts/patch-maplibre-dist.js"
  },
  "dependencies": {
    "echarts": "^5.6.0",
    "maplibre-gl": "5.21.0",
    "next": "^16.2.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5"
  }
}
