{
  "version": "0.1",
  "layer_overrides": {
    "warming_air": { "default_graph_ids": ["t2m_annual"] },
    "warming_vs_preindustrial_air": { "default_graph_ids": ["t2m_annual"] },
    "warming_sst": { "default_graph_ids": ["sst_annual"] },
    "reef_stress": { "default_graph_ids": ["dhw_risk_days"] },
    "precipitation_trend": { "default_graph_ids": ["tp_annual"] }
  },
  "panels": {
    "air_temperature": {
      "title": "Air Temperature",
      "score_map_id": "t2m_trend_score",
      "graphs": [
        {
          "id": "t2m_annual",
          "headline": {
            "type": "air_temp",
            "primary_metric_local": "t2m_vs_preindustrial_local",
            "primary_metric_global": "t2m_vs_preindustrial_global",
            "recent_metric_local": "t2m_recent_local",
            "recent_metric_global": "t2m_recent_global",
            "info_bubble_texts": {
              "air_temp": "The warming since the pre-industrial era (1850–1900) is estimated by combining two sources: the local ERA5 warming since the 1979–2000 reference period, plus a pre-1979 offset derived from a 5-model CMIP mean that estimates how much warming occurred between 1850–1900 and 1979–2000 before the ERA5 record begins."
            }
          },
          "title": "Annual air temperature",
          "ui": {
            "info_text": "Annual air temperature is derived from daily air temperature at 2 meters above the surface, aggregated into monthly and yearly averages for 1979-2025. We show a zoomed-in version of the daily and monthly temperatures over 5 years (2021-2025) that reflects seasonal changes. Source: CDS.",
            "chart_mode": "temperature_line",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Temperature ({unit})",
          "source": "CDS ERA5 2m temperature daily means (2021-2025), aggregated to monthly and yearly means (1979-2025)",
          "animation": {
            "autoplay": false,
            "loop": false,
            "steps": [
              {
                "id": "all_years",
                "title": "Climate",
                "series_keys": [
                  "t2m_yearly_mean",
                  "t2m_yearly_mean_5y",
                  "t2m_yearly_trend"
                ]
              },
              {
                "id": "zoom_in",
                "title": "Seasons",
                "time_range": { "last": { "value": 5, "unit": "years" } },
                "series_keys": [
                  "t2m_daily_mean",
                  "t2m_monthly_mean",
                  "t2m_monthly_trend"
                ]
              }
            ]
          },
          "series": [
            {
              "key": "t2m_daily_mean",
              "metric": "t2m_daily_mean_c",
              "label": "Daily mean",
              "ui": { "role": "raw" },
              "unit": "C",
              "style": { "type": "line", "color": "rgba(180,180,180,0.7)" }
            },
            {
              "key": "t2m_monthly_mean",
              "metric": "t2m_monthly_mean_c",
              "label": "Monthly mean",
              "ui": { "role": "mean" },
              "unit": "C",
              "style": { "type": "line", "color": "#1736ff" }
            },
            {
              "key": "t2m_yearly_mean",
              "metric": "t2m_yearly_mean_c",
              "label": "Annual mean",
              "ui": { "role": "raw" },
              "unit": "C",
              "style": { "type": "line", "color": "#ff2e55" }
            },
            {
              "key": "t2m_yearly_mean_5y",
              "metric": "t2m_yearly_mean_c",
              "label": "5-year mean",
              "ui": { "role": "mean" },
              "unit": "C",
              "style": { "type": "line", "color": "#1736ff" },
              "transform": {
                "fn": "rolling_mean",
                "params": { "window": 5, "centered": true }
              },
              "annotations": [
                { "type": "min", "label": "Minimum" },
                { "type": "max", "label": "Maximum" }
              ]
            },
            {
              "key": "t2m_yearly_trend",
              "metric": "t2m_yearly_mean_c",
              "label": "Trend",
              "ui": { "role": "trend" },
              "unit": "C",
              "style": { "type": "line", "color": "rgba(255,0,0,0.24)" },
              "transform": { "fn": "linear_trend_line" }
            },
            {
              "key": "t2m_monthly_trend",
              "metric": "t2m_monthly_mean_c",
              "label": "Trend",
              "ui": { "role": "trend" },
              "unit": "C",
              "style": { "type": "line", "color": "rgba(255,0,0,0.24)" },
              "transform": {
                "fn": "linear_trend_line",
                "params": { "extend_to": "2025-12-31" }
              }
            }
          ]
        },
        {
          "id": "t2m_hot_days",
          "headline": {
            "type": "trend",
            "metric_local": "t2m_hotdays_local",
            "metric_global": "t2m_hotdays_global",
            "unit": "day",
            "label": "the number of hot days has shifted by",
            "label_no_change": "the number of hot days has not changed"
          },
          "title": "Number of hot days",
          "ui": {
            "info_text": "Number of hot days per year are counted as days warmer than the top 10% warmest days in a 10-year baseline starting in 1979, for 1979-2025. Source: CDS.",
            "chart_mode": "hot_days_combo",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Days/year",
          "source": "CDS ERA5 2m temperature daily means (1979-2025)",
          "series": [
            {
              "key": "t2m_hotdays",
              "metric": "t2m_hotdays_per_year",
              "label": "Hot days",
              "ui": { "role": "raw" },
              "unit": "days",
              "style": { "type": "bar", "color": "#ccccff" }
            },
            {
              "key": "t2m_hotdays_5y",
              "metric": "t2m_hotdays_per_year",
              "label": "5-year mean",
              "ui": { "role": "mean" },
              "unit": "days",
              "style": { "type": "line", "color": "#1736ff" },
              "transform": {
                "fn": "rolling_mean",
                "params": { "window": 5, "centered": true }
              }
            },
            {
              "key": "t2m_hotdays_trend",
              "metric": "t2m_hotdays_per_year",
              "label": "Trend",
              "ui": { "role": "trend" },
              "unit": "days",
              "style": { "type": "line", "color": "rgba(255,0,0,0.24)" },
              "transform": { "fn": "linear_trend_line" }
            }
          ]
        }
      ]
    },
    "sea_temperature": {
      "title": "Sea Surface Temperature",
      "score_map_id": "sst_trend_score",
      "graphs": [
        {
          "id": "sst_annual",
          "headline": {
            "type": "sea_temp",
            "metric_local": "sst_recent_local",
            "metric_global": "sst_recent_global",
            "positive_action": "the sea has warmed by",
            "no_warming_text": "the sea has not warmed since 1982."
          },
          "title": "Annual sea surface temperature",
          "ui": {
            "info_text": "Annual sea surface temperature is derived from daily sea surface temperature, aggregated into yearly averages for 1982-2025. Source: ERDDAP.",
            "chart_mode": "temperature_line",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Temperature ({unit})",
          "source": "ERDDAP OISST v2.1 daily sea surface temperature (1982-2025), aggregated to yearly means",
          "series": [
            {
              "key": "sst_yearly_mean",
              "metric": "sst_yearly_mean_c",
              "label": "Annual mean",
              "ui": { "role": "raw" },
              "unit": "C",
              "style": { "type": "line", "color": "#ff2e55" }
            },
            {
              "key": "sst_yearly_mean_5y",
              "metric": "sst_yearly_mean_c",
              "label": "5-year mean",
              "ui": { "role": "mean" },
              "unit": "C",
              "style": { "type": "line", "color": "#1736ff" },
              "transform": {
                "fn": "rolling_mean",
                "params": { "window": 5, "centered": true }
              },
              "annotations": [
                { "type": "min", "label": "Minimum" },
                { "type": "max", "label": "Maximum" }
              ]
            },
            {
              "key": "sst_yearly_trend",
              "metric": "sst_yearly_mean_c",
              "label": "Trend",
              "ui": { "role": "trend" },
              "unit": "C",
              "style": { "type": "line", "color": "rgba(255,0,0,0.24)" },
              "transform": { "fn": "linear_trend_line" }
            }
          ]
        },
        {
          "id": "sst_hot_days",
          "headline": {
            "type": "trend",
            "metric_local": "sst_hotdays_local",
            "metric_global": "sst_hotdays_global",
            "unit": "day",
            "label": "the number of sea hot days has shifted by",
            "label_no_change": "the number of sea hot days has not changed",
            "unavailable_global_metric": "sst_recent_global"
          },
          "title": "Number of sea surface hot days",
          "ui": {
            "info_text": "Number of sea surface hot days per year are counted as days where the sea surface temperature is warmer than the top 10% warmest days in a 10-year baseline starting in 1982, for 1982-2025. Source: ERDDAP.",
            "chart_mode": "hot_days_combo",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Days/year",
          "source": "ERDDAP OISST v2.1 daily sea surface temperature (1982-2025)",
          "series": [
            {
              "key": "sst_hotdays",
              "metric": "sst_hotdays_per_year",
              "label": "Hot days",
              "ui": { "role": "raw" },
              "unit": "days",
              "style": { "type": "bar", "color": "#ccccff" }
            },
            {
              "key": "sst_hotdays_5y",
              "metric": "sst_hotdays_per_year",
              "label": "5-year mean",
              "ui": { "role": "mean" },
              "unit": "days",
              "style": { "type": "line", "color": "#1736ff" },
              "transform": {
                "fn": "rolling_mean",
                "params": { "window": 5, "centered": true }
              }
            },
            {
              "key": "sst_hotdays_trend",
              "metric": "sst_hotdays_per_year",
              "label": "Trend",
              "ui": { "role": "trend" },
              "unit": "days",
              "style": { "type": "line", "color": "rgba(255,0,0,0.24)" },
              "transform": { "fn": "linear_trend_line" }
            }
          ]
        }
      ]
    },
    "precipitation": {
      "title": "Precipitation",
      "score_map_id": "tp_annual_trend_score",
      "graphs": [
        {
          "id": "tp_annual",
          "headline": {
            "type": "trend",
            "metric_local": "precip_local",
            "metric_global": "precip_global",
            "unit": "mm",
            "label": "the precipitation level has shifted by",
            "label_no_change": "the precipitation level has not changed"
          },
          "title": "Annual total precipitation",
          "ui": {
            "info_text": "Annual total precipitation is derived from daily ERA5 total precipitation, summed into yearly totals for 1979-2025. Source: CDS. Note: ERA5 precipitation trends may be inflated by changes in the satellite observing system over time.",
            "chart_mode": "temperature_line",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Precipitation (mm)",
          "source": "CDS ERA5 daily total precipitation (1979-2025), aggregated to yearly sums",
          "series": [
            {
              "key": "tp_yearly_total",
              "metric": "tp_annual_total_mm",
              "label": "Annual total",
              "ui": { "role": "raw" },
              "unit": "mm",
              "style": { "type": "line", "color": "#000000" }
            },
            {
              "key": "tp_yearly_total_5y",
              "metric": "tp_annual_total_mm",
              "label": "5-year mean",
              "ui": { "role": "mean" },
              "unit": "mm",
              "style": { "type": "line", "color": "#1736ff" },
              "transform": {
                "fn": "rolling_mean",
                "params": { "window": 5, "centered": true }
              },
              "annotations": [
                { "type": "min", "label": "Minimum" },
                { "type": "max", "label": "Maximum" }
              ]
            },
            {
              "key": "tp_yearly_trend",
              "metric": "tp_annual_total_mm",
              "label": "Trend",
              "ui": { "role": "trend" },
              "unit": "mm",
              "style": { "type": "line", "color": "rgba(0,0,255,0.24)" },
              "transform": { "fn": "linear_trend_line" }
            }
          ]
        },
        {
          "id": "tp_cdd",
          "headline": {
            "type": "trend",
            "metric_local": "cdd_local",
            "metric_global": "cdd_global",
            "unit": "day",
            "label": "the number of consecutive dry days has shifted by",
            "label_no_change": "the number of consecutive dry days has not changed"
          },
          "title": "Consecutive dry days",
          "ui": {
            "info_text": "Maximum number of consecutive dry days (daily precipitation < 1 mm) per year for 1979-2025. Source: CDS. Note: ERA5 precipitation trends may be inflated by changes in the satellite observing system over time.",
            "chart_mode": "hot_days_combo",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Days/year",
          "source": "CDS ERA5 daily total precipitation (1979-2025)",
          "series": [
            {
              "key": "tp_cdd",
              "metric": "tp_cdd_per_year",
              "label": "Max dry spell",
              "ui": { "role": "raw" },
              "unit": "days",
              "style": {
                "type": "bar",
                "color": "#B9BAB8",
                "accent_color": "#000000"
              }
            },
            {
              "key": "tp_cdd_5y",
              "metric": "tp_cdd_per_year",
              "label": "5-year mean",
              "ui": { "role": "mean" },
              "unit": "days",
              "style": { "type": "line", "color": "#1736ff" },
              "transform": {
                "fn": "rolling_mean",
                "params": { "window": 5, "centered": true }
              }
            },
            {
              "key": "tp_cdd_trend",
              "metric": "tp_cdd_per_year",
              "label": "Trend",
              "ui": { "role": "trend" },
              "unit": "days",
              "style": { "type": "line", "color": "rgba(0,0,255,0.24)" },
              "transform": { "fn": "linear_trend_line" }
            }
          ]
        }
      ]
    },
    "coral_reef_dhw": {
      "title": "Coral Reef Heat Stress",
      "score_map_id": "reef_domain_presence_score",
      "graphs": [
        {
          "id": "dhw_risk_days",
          "headline": {
            "type": "coral",
            "global_trend_metric": "dhw_combined_global",
            "local_check_metric": "dhw_severe_local",
            "worst_year_metric": "dhw_worst_year_local",
            "worst_year_days_metric": "dhw_worst_year_days_local",
            "select_layer_id": "reef_stress",
            "select_layer_fly_to_reef": true,
            "info_bubble_texts": {
              "coral_worst_year": "The worst year is the calendar year with the highest combined total of moderate (4 ≤ DHW < 8) and severe (DHW ≥ 8) heat stress days in the observed record since 1985.",
              "trend": "The change is estimated from a linear trend fitted to global coral heat stress data since 1985, counting combined moderate (4 ≤ DHW < 8) and severe (DHW ≥ 8) days per year.",
              "coral_unavailable": "The change is estimated from a linear trend fitted to global coral heat stress data since 1985, counting combined moderate (4 ≤ DHW < 8) and severe (DHW ≥ 8) days per year."
            }
          },
          "title": "Coral reef DHW risk days",
          "ui": {
            "info_text": "This graph shows the number of days per year that coral reefs experienced each DHW (Degree Heating Weeks) heat-stress level for 1985-2025: no risk (DHW < 4), moderate risk (4 <= DHW < 8), and severe risk (DHW >= 8). DHW measures accumulated ocean heat stress over the previous 12 weeks; more days in higher DHW categories indicate greater bleaching risk. Note: 1985 shows fewer total days because the dataset begins in March 1985. Source: ERDDAP.",
            "chart_mode": "stacked_bar",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Number of days",
          "source": "NOAA Coral Reef Watch daily Degree Heating Week (1985-2025)",
          "series": [
            {
              "key": "dhw_no_risk_days",
              "metric": "dhw_no_risk_days_per_year",
              "label": "No risk (DHW < 4)",
              "shortLabel": "No risk",
              "ui": { "role": "category" },
              "unit": "days",
              "style": {
                "type": "bar",
                "color": "#ccccff",
                "stack": "dhw_risk_days"
              }
            },
            {
              "key": "dhw_moderate_risk_days",
              "metric": "dhw_moderate_risk_days_per_year",
              "label": "Moderate risk (4 <= DHW < 8)",
              "shortLabel": "Moderate risk",
              "ui": { "role": "category" },
              "unit": "days",
              "style": {
                "type": "bar",
                "color": "#fdd835",
                "stack": "dhw_risk_days"
              }
            },
            {
              "key": "dhw_severe_risk_days",
              "metric": "dhw_severe_risk_days_per_year",
              "label": "Severe risk (DHW >= 8)",
              "shortLabel": "Severe risk",
              "ui": { "role": "category" },
              "unit": "days",
              "style": {
                "type": "bar",
                "color": "#ff0000",
                "stack": "dhw_risk_days"
              }
            }
          ]
        }
      ]
    }
  }
}
