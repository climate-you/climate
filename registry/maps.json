    "title": "Air temperature anomaly in 2025 vs 1979-1988",
    "type": "texture_png",
    "source_metric": "t2m_yearly_mean_c",
    "reducer": {
      "op": "anomaly_vs_mean",
      "target_year": 2025,
      "baseline_start_year": 1979,
      "baseline_end_year": 1988
    },
    "palette": {
      "colors": ["#313695", "#74add1", "#f7f7f7", "#f46d43", "#a50026"],
      "nan_color": "#000000"
    },
    "scale": {
      "mode": "linear",
      "vmin": -3.0,
      "vmax": 3.0
    },
    "output": {
      "filename": "t2m_warming_2025_vs_1979_1988.png"
    }
  },
