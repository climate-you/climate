    }
  },
  "dhw_moderate_risk_days_per_year": {
    "id": "dhw_moderate_risk_days_per_year",
    "title": "Coral reef DHW moderate-risk days per year",
    "unit": "days",
    "dtype": "float32",
    "missing": "nan",
    "domain": "dataset_mask",
    "time_axis": "yearly",
    "source": {
      "type": "erddap",
      "dataset_ref": "crw_dhw_daily",
      "agg": "dhw_moderate_risk_days_per_year"
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "dhw_severe_risk_days_per_year": {
    "id": "dhw_severe_risk_days_per_year",
    "title": "Coral reef DHW severe-risk days per year",
    "unit": "days",
    "dtype": "float32",
    "missing": "nan",
    "domain": "dataset_mask",
    "time_axis": "yearly",
    "source": {
      "type": "erddap",
      "dataset_ref": "crw_dhw_daily",
      "agg": "dhw_severe_risk_days_per_year"
    },
    "storage": {
