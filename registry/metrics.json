{
  "version": "0.1",
  "t2m_yearly_mean_c": {
    "id": "t2m_yearly_mean_c",
    "title": "2m temperature yearly mean",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "yearly",
    "source": {
      "type": "cds",
      "dataset_ref": "era5_daily_t2m",
      "batch_tiles_override": 4,
      "agg": "annual_mean_from_daily",
      "time_range": { "start_year": 1979, "end_year": 2025 }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "t2m_yearly_5y_mean_c": {
    "id": "t2m_yearly_5y_mean_c",
    "title": "2m temperature 5y rolling mean",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "yearly",
    "source": {
      "type": "derived",
      "inputs": ["t2m_yearly_mean_c"],
      "steps": [
        { "fn": "rolling_mean", "params": { "window": 5, "centered": true } }
      ]
    },
    "materialize": "on_api"
  },
  "t2m_cmip_offset_1979_2000_vs_1850_1900_mean_5models_c": {
    "id": "t2m_cmip_offset_1979_2000_vs_1850_1900_mean_5models_c",
    "title": "CMIP6 local offset mean: 1979-2000 vs 1850-1900 (5-model mean)",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "yearly",
    "source": {
      "type": "cds",
      "dataset_ref": "cmip6_historical_tas_monthly_5model_mean",
      "agg": "cmip_multi_model_offset_from_monthly",
      "params": {
        "preindustrial_start_year": 1850,
        "preindustrial_end_year": 1900,
        "ref_start_year": 1979,
        "ref_end_year": 2000,
        "label_year": 2000
      },
      "time_range": { "start_year": 1850, "end_year": 2000 }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "t2m_monthly_mean_c": {
    "id": "t2m_monthly_mean_c",
    "title": "2m temperature monthly mean",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "monthly",
    "source": {
      "type": "cds",
      "dataset_ref": "era5_daily_t2m",
      "batch_tiles_override": 4,
      "agg": "monthly_mean_from_daily",
      "time_range": { "start_year": 1979, "end_year": 2025 }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "t2m_daily_mean_c": {
    "id": "t2m_daily_mean_c",
    "title": "2m temperature daily mean",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "daily",
    "source": {
      "type": "cds",
      "dataset_ref": "era5_daily_t2m",
      "batch_tiles_override": 4,
      "agg": "identity",
      "params": {
        "daily_statistic": "daily_mean"
      },
      "time_range": { "start_year": 2021, "end_year": 2025 }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "t2m_hotdays_per_year": {
    "id": "t2m_hotdays_per_year",
    "title": "T2m hot days per year",
    "unit": "days",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "yearly",
    "source": {
      "type": "cds",
      "dataset_ref": "era5_daily_t2m",
      "batch_tiles_override": 4,
      "agg": "hot_days_per_year",
      "params": {
        "baseline_years": 10,
        "percentile": 90,
        "daily_statistic": "daily_mean"
      }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "tp_annual_total_mm": {
    "id": "tp_annual_total_mm",
    "title": "Total precipitation yearly sum",
    "unit": "mm",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "yearly",
    "source": {
      "type": "cds",
      "dataset_ref": "era5_daily_tp",
      "batch_tiles_override": 4,
      "agg": "annual_sum_from_daily",
      "time_range": { "start_year": 1979, "end_year": 2025 }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "tp_max_dry_spell_summer_days_per_year": {
    "id": "tp_max_dry_spell_summer_days_per_year",
    "title": "Maximum summer dry-spell length per year",
    "unit": "days",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "yearly",
    "source": {
      "type": "cds",
      "dataset_ref": "era5_daily_tp",
      "batch_tiles_override": 4,
      "agg": "max_dry_spell_summer_per_year",
      "params": {
        "dry_day_threshold_mm": 1.0,
        "north_summer_months": [6, 7, 8],
        "south_summer_months": [12, 1, 2]
      },
      "time_range": { "start_year": 1979, "end_year": 2025 }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "sst_yearly_mean_c": {
    "id": "sst_yearly_mean_c",
    "title": "SST yearly mean",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "domain": "ocean",
    "time_axis": "yearly",
    "source": {
      "type": "erddap",
      "dataset_ref": "oisst_sst_v21_daily",
      "agg": "annual_mean_from_daily"
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "sst_hotdays_per_year": {
    "id": "sst_hotdays_per_year",
    "title": "SST hot days per year",
    "unit": "days",
    "dtype": "float32",
    "missing": "nan",
    "domain": "ocean",
    "time_axis": "yearly",
    "source": {
      "type": "erddap",
      "dataset_ref": "oisst_sst_v21_daily",
      "agg": "hot_days_per_year",
      "params": { "baseline_years": 10, "percentile": 90 }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "dhw_no_risk_days_per_year": {
    "id": "dhw_no_risk_days_per_year",
    "title": "Coral reef DHW no-risk days per year",
    "unit": "days",
    "dtype": "float32",
    "missing": "nan",
    "domain": "dataset_mask",
    "time_axis": "yearly",
    "source": {
      "type": "erddap",
      "dataset_ref": "crw_dhw_daily",
