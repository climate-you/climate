# Climate API environment variables (copy to /etc/climate/backend.env)
# Adjust paths to your VM deployment location.

API_HOST=127.0.0.1
API_PORT=8001

REPO_ROOT=/opt/climate/source
RELEASE=latest
RELEASES_ROOT=/opt/climate/source/data/releases
LATEST_RELEASE_FILE=/opt/climate/source/data/releases/LATEST
LOCATIONS_CSV=/opt/climate/source/data/locations/locations.csv
LOCATIONS_INDEX_CSV=/opt/climate/source/data/locations/locations.index.csv
KDTREE_PATH=/opt/climate/source/data/locations/locations.kdtree.pkl
OCEAN_MASK_NPZ=/opt/climate/source/data/locations/ocean_mask.npz
OCEAN_NAMES_JSON=/opt/climate/source/data/locations/ocean_names.json

# Cache and preload
REDIS_URL=
TTL_RESOLVE_S=86400
TTL_PANEL_S=86400
SCORE_MAP_PRELOAD=1

# Production CORS: comma-separated origins, no spaces.
# Example: CORS_ALLOW_ORIGINS=https://your-domain.com,https://www.your-domain.com
CORS_ALLOW_ORIGINS=https://example.com
CORS_ALLOW_CREDENTIALS=1

# Analytics
ANALYTICS_DB_PATH=/opt/climate/source/data/analytics/events.db
ANALYTICS_ENABLED=1
# ANALYTICS_IP_BLOCKLIST=/opt/climate/source/data/analytics/ip_blocklist.txt  # optional; defaults to this path
GEOIP_CACHE_TTL_S=3600

# Chat / LLM assistant
# Set CHAT_ENABLED=1 to activate the /api/chat endpoint.
# CHAT_DEV_MODE defaults to 1 (safe). Set to 0 in production to use the 70b model chain.
# See docs/runbooks/chat.md for the full setup guide.
CHAT_ENABLED=1
CHAT_DEV_MODE=0
GROQ_API_KEY_FREE=your_groq_free_key_here
# GROQ_API_KEY_PAID=your_groq_paid_key_here  # optional; used as Tier 2 (70b paid) in prod chain
# OLLAMA_BASE_URL=http://localhost:11434      # optional; local model fallback (dev chain only)
# OLLAMA_MODEL=qwen2.5:14b

