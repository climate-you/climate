{
  "version": "0.1",
  "t2m_yearly_mean_c": {
    "id": "t2m_yearly_mean_c",
    "title": "2m temperature yearly mean",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "time_axis": "yearly",
    "source": {
      "type": "cds",
      "dataset_ref": "era5_monthly_t2m",
      "agg": "annual_mean_from_monthly"
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "t2m_yearly_5y_mean_c": {
    "id": "t2m_yearly_5y_mean_c",
    "title": "2m temperature 5y rolling mean",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "time_axis": "yearly",
    "source": {
      "type": "derived",
      "inputs": ["t2m_yearly_mean_c"],
      "steps": [
        { "fn": "rolling_mean", "params": { "window": 5, "centered": true } }
      ]
    },
    "materialize": "on_api"
  },
  "t2m_hotdays_per_year": {
    "id": "t2m_hotdays_per_year",
    "title": "T2m hot days per year",
    "unit": "days",
    "dtype": "float32",
    "missing": "nan",
    "time_axis": "yearly",
    "source": {
      "type": "cds",
      "dataset_ref": "era5_daily_t2m",
      "agg": "hot_days_per_year",
      "params": {
        "baseline_years": 10,
        "percentile": 90,
        "daily_statistic": "daily_mean"
      }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "sst_yearly_mean_c": {
    "id": "sst_yearly_mean_c",
    "title": "SST yearly mean",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "time_axis": "yearly",
    "source": {
      "type": "erddap",
      "dataset_ref": "oisst_sst_v21_daily",
      "agg": "annual_mean_from_daily"
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "sst_hotdays_per_year": {
    "id": "sst_hotdays_per_year",
    "title": "SST hot days per year",
    "unit": "days",
    "dtype": "float32",
    "missing": "nan",
    "time_axis": "yearly",
    "source": {
      "type": "erddap",
      "dataset_ref": "oisst_sst_v21_daily",
      "agg": "hot_days_per_year",
      "params": { "baseline_years": 10, "percentile": 90 }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "dummy1_yearly_mean_c": {
    "id": "dummy1_yearly_mean_c",
    "title": "Dummy metric (0.25° grid)",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "time_axis": "yearly",
    "source": {
      "type": "derived",
      "inputs": ["t2m_yearly_mean_c"],
      "steps": ["identity"]
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "none" }
    }
  },
  "dummy2_yearly_mean_c": {
    "id": "dummy2_yearly_mean_c",
    "title": "Dummy metric (0.25° grid)",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "time_axis": "yearly",
    "source": {
      "type": "derived",
      "inputs": ["t2m_yearly_mean_c"],
      "steps": ["identity"]
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "none" }
    }
  }
}
