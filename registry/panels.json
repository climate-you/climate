{
  "version": "0.1",
  "panels": {
    "air_temperature": {
      "title": "Air Temperature",
      "score_map_id": "t2m_trend_score",
      "graphs": [
        {
          "id": "t2m_annual",
          "title": "Annual temperature",
          "ui": {
            "info_text": "Annual air temperature is derived from daily air temperature at 2 meters above the surface, aggregated into monthly and yearly averages. We show a zoomed-in version of the daily and monthly temperatures over 5 years that reflects seasonal changes.",
            "chart_mode": "temperature_line",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Temperature ({unit})",
          "source": "CDS ERA5 daily and monthly 2m temperature means (1979-2025)",
          "animation": {
            "autoplay": false,
            "loop": false,
            "steps": [
              {
                "id": "all_years",
                "title": "Climate",
                "series_keys": [
                  "t2m_yearly_mean",
                  "t2m_yearly_mean_5y",
                  "t2m_yearly_trend"
                ]
              },
              {
                "id": "zoom_in",
                "title": "Seasons",
                "time_range": { "last": { "value": 5, "unit": "years" } },
                "series_keys": [
                  "t2m_daily_mean",
                  "t2m_monthly_mean",
                  "t2m_monthly_trend"
                ]
              }
            ]
          },
          "series": [
            {
              "key": "t2m_daily_mean",
              "metric": "t2m_daily_mean_c",
              "label": "Daily mean",
              "ui": { "role": "raw" },
              "unit": "C",
              "style": { "type": "line", "color": "rgba(180,180,180,0.7)" }
            },
            {
              "key": "t2m_monthly_mean",
              "metric": "t2m_monthly_mean_c",
              "label": "Monthly mean",
              "ui": { "role": "mean" },
              "unit": "C",
              "style": { "type": "line", "color": "#1736ff" }
            },
            {
              "key": "t2m_yearly_mean",
              "metric": "t2m_yearly_mean_c",
              "label": "Annual mean",
              "ui": { "role": "raw" },
              "unit": "C",
              "style": { "type": "line", "color": "#ff2e55" }
            },
            {
              "key": "t2m_yearly_mean_5y",
              "metric": "t2m_yearly_mean_c",
              "label": "5-year mean",
              "ui": { "role": "mean" },
              "unit": "C",
              "style": { "type": "line", "color": "#1736ff" },
              "transform": {
                "fn": "rolling_mean",
                "params": { "window": 5, "centered": true }
              },
              "annotations": [
                { "type": "min", "label": "Minimum" },
                { "type": "max", "label": "Maximum" }
              ]
            },
            {
              "key": "t2m_yearly_trend",
              "metric": "t2m_yearly_mean_c",
              "label": "Trend",
              "ui": { "role": "trend" },
              "unit": "C",
              "style": { "type": "line", "color": "rgba(255,0,0,0.24)" },
              "transform": { "fn": "linear_trend_line" }
            },
            {
              "key": "t2m_monthly_trend",
              "metric": "t2m_monthly_mean_c",
              "label": "Trend",
              "ui": { "role": "trend" },
              "unit": "C",
              "style": { "type": "line", "color": "rgba(255,0,0,0.24)" },
              "transform": {
                "fn": "linear_trend_line",
                "params": { "extend_to": "2025-12-31" }
              }
            }
          ]
        },
        {
          "id": "t2m_hot_days",
          "title": "Number of hot days",
          "ui": {
            "info_text": "Number of hot days per year are counted as days warmer than the top 10% warmest days in a 10-year baseline starting in 1979.",
            "chart_mode": "hot_days_combo",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Days/year",
          "source": "CDS ERA5 2m temperature daily means (1979-2025)",
          "series": [
            {
              "key": "t2m_hotdays",
              "metric": "t2m_hotdays_per_year",
              "label": "Hot days",
              "ui": { "role": "raw" },
              "unit": "days",
              "style": { "type": "bar", "color": "#ccccff" }
            },
            {
              "key": "t2m_hotdays_5y",
              "metric": "t2m_hotdays_per_year",
              "label": "5-year mean",
              "ui": { "role": "mean" },
              "unit": "days",
              "style": { "type": "line", "color": "#1736ff" },
              "transform": {
                "fn": "rolling_mean",
                "params": { "window": 5, "centered": true }
              }
            },
            {
              "key": "t2m_hotdays_trend",
              "metric": "t2m_hotdays_per_year",
              "label": "Trend",
              "ui": { "role": "trend" },
              "unit": "days",
              "style": { "type": "line", "color": "rgba(255,0,0,0.24)" },
              "transform": { "fn": "linear_trend_line" }
            }
          ]
        }
      ]
    },
    "sea_temperature": {
      "title": "Sea Surface Temperature",
      "score_map_id": "sst_trend_score",
      "graphs": [
        {
          "id": "sst_annual",
          "title": "Annual sea surface temperature",
          "ui": {
            "info_text": "Annual sea surface temperature is derived from daily sea surface temperature, aggregated into yearly averages.",
            "chart_mode": "temperature_line",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Temperature ({unit})",
          "source": "ERDDAP SST temperature daily means (2021-2025)",
          "series": [
            {
              "key": "sst_yearly_mean",
              "metric": "sst_yearly_mean_c",
              "label": "Annual mean",
              "ui": { "role": "raw" },
              "unit": "C",
              "style": { "type": "line", "color": "#ff2e55" }
            },
            {
              "key": "sst_yearly_mean_5y",
              "metric": "sst_yearly_mean_c",
              "label": "5-year mean",
              "ui": { "role": "mean" },
              "unit": "C",
              "style": { "type": "line", "color": "#1736ff" },
              "transform": {
                "fn": "rolling_mean",
                "params": { "window": 5, "centered": true }
              },
              "annotations": [
                { "type": "min", "label": "Minimum" },
                { "type": "max", "label": "Maximum" }
              ]
            },
            {
              "key": "sst_yearly_trend",
              "metric": "sst_yearly_mean_c",
              "label": "Trend",
              "ui": { "role": "trend" },
              "unit": "C",
              "style": { "type": "line", "color": "rgba(255,0,0,0.24)" },
              "transform": { "fn": "linear_trend_line" }
            }
          ]
        },
        {
          "id": "sst_hot_days",
          "title": "Number of sea surface hot days",
          "ui": {
            "info_text": "Number of sea surface hot days per year are counted as days where the sea surface temperature is warmer than the top 10% warmest days in a 10-year baseline starting in 1979.",
            "chart_mode": "hot_days_combo",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Days/year",
          "source": "ERDDAP OISST daily means (2021-2025)",
          "series": [
            {
              "key": "sst_hotdays",
              "metric": "sst_hotdays_per_year",
              "label": "Hot days",
              "ui": { "role": "raw" },
              "unit": "days",
              "style": { "type": "bar", "color": "#ccccff" }
            },
            {
              "key": "sst_hotdays_5y",
              "metric": "sst_hotdays_per_year",
              "label": "5-year mean",
              "ui": { "role": "mean" },
              "unit": "days",
              "style": { "type": "line", "color": "#1736ff" },
              "transform": {
                "fn": "rolling_mean",
                "params": { "window": 5, "centered": true }
              }
            },
            {
              "key": "sst_hotdays_trend",
              "metric": "sst_hotdays_per_year",
              "label": "Trend",
              "ui": { "role": "trend" },
              "unit": "days",
              "style": { "type": "line", "color": "rgba(255,0,0,0.24)" },
              "transform": { "fn": "linear_trend_line" }
            }
          ]
        }
      ]
    },
    "coral_reef_dhw": {
      "title": "Coral Reef Heat Stress",
      "score_map_id": "reef_domain_presence_score",
      "graphs": [
        {
          "id": "dhw_risk_days",
          "title": "Coral Reef DHW risk days per year",
          "ui": {
            "info_text": "Coral Reef DHW categories: no risk (DHW < 4), moderate risk (4 <= DHW < 8), severe risk (DHW >= 8).",
            "chart_mode": "stacked_bar",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Number of days",
          "source": "NOAA Coral Reef Watch daily Degree Heating Week (1985-2025)",
          "series": [
            {
              "key": "dhw_no_risk_days",
              "metric": "dhw_no_risk_days_per_year",
              "label": "No risk (DHW < 4)",
              "ui": { "role": "category" },
              "unit": "days",
              "style": {
                "type": "bar",
                "color": "#33a02c",
                "stack": "dhw_risk_days"
              }
            },
            {
              "key": "dhw_moderate_risk_days",
              "metric": "dhw_moderate_risk_days_per_year",
              "label": "Moderate risk (4 <= DHW < 8)",
              "ui": { "role": "category" },
              "unit": "days",
              "style": {
                "type": "bar",
                "color": "#fdd835",
                "stack": "dhw_risk_days"
              }
            },
            {
              "key": "dhw_severe_risk_days",
              "metric": "dhw_severe_risk_days_per_year",
              "label": "Severe risk (DHW >= 8)",
              "ui": { "role": "category" },
              "unit": "days",
              "style": {
                "type": "bar",
                "color": "#e53935",
                "stack": "dhw_risk_days"
              }
            }
          ]
        }
      ]
    }
  }
}
