{
  "version": "0.1",
  "t2m_yearly_mean_c": {
    "id": "t2m_yearly_mean_c",
    "title": "2m temperature yearly mean",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "yearly",
    "rankings": ["mean", "trend_slope"],
    "aggregates": ["mean", "min", "max"],
    "source": {
      "type": "cds",
      "dataset_ref": "era5_daily_t2m",
      "batch_tiles_override": 4,
      "agg": "annual_mean_from_daily",
      "time_range": { "start_year": 1979, "end_year": 2025 }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "t2m_trend_1979_2025_c_per_decade": {
    "id": "t2m_trend_1979_2025_c_per_decade",
    "title": "2m temperature warming trend 1979–2025",
    "unit": "C/decade",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "yearly",
    "llm_note": "Use this for 'fastest warming', 'most warming since 1979', or 'warming trend' ranking questions. Prefer this over t2m_yearly_mean_c with aggregation=trend_slope.",
    "rankings": ["mean"],
    "aggregates": ["mean"],
    "source": {
      "type": "derived",
      "inputs": ["t2m_yearly_mean_c"],
      "steps": [
        {
          "fn": "trend_slope_per_decade",
          "params": { "label_year": 2025 }
        }
      ]
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "t2m_total_warming_vs_preindustrial_c": {
    "id": "t2m_total_warming_vs_preindustrial_c",
    "title": "2m temperature total warming since pre-industrial (1850–1900) to 2021–2025",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "yearly",
    "llm_note": "Use this for 'warmed most since pre-industrial times' or 'total warming since 1850' questions.",
    "rankings": ["mean"],
    "aggregates": ["mean"],
    "source": {
      "type": "derived",
      "inputs": [
        "t2m_yearly_mean_c",
        "t2m_cmip_offset_1979_2000_vs_1850_1900_mean_5models_c"
      ],
      "steps": [
        {
          "fn": "blended_preindustrial_anomaly",
          "params": {
            "recent_start_year": 2021,
            "recent_end_year": 2025,
            "era5_ref_start_year": 1979,
            "era5_ref_end_year": 2000,
            "label_year": 2025
          }
        }
      ]
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "t2m_yearly_5y_mean_c": {
    "id": "t2m_yearly_5y_mean_c",
    "title": "2m temperature 5y rolling mean",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "yearly",
    "source": {
      "type": "derived",
      "inputs": ["t2m_yearly_mean_c"],
      "steps": [
        { "fn": "rolling_mean", "params": { "window": 5, "centered": true } }
      ]
    },
    "materialize": "on_api"
  },
  "t2m_cmip_offset_1979_2000_vs_1850_1900_mean_5models_c": {
    "id": "t2m_cmip_offset_1979_2000_vs_1850_1900_mean_5models_c",
    "title": "CMIP6 local offset mean: 1979-2000 vs 1850-1900 (5-model mean)",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "yearly",
    "llm_hidden": true,
    "source": {
      "type": "cds",
      "dataset_ref": "cmip6_historical_tas_monthly_5model_mean",
      "agg": "cmip_multi_model_offset_from_monthly",
      "params": {
        "preindustrial_start_year": 1850,
        "preindustrial_end_year": 1900,
        "ref_start_year": 1979,
        "ref_end_year": 2000,
        "label_year": 2000
      },
      "time_range": { "start_year": 1850, "end_year": 2000 }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "t2m_monthly_mean_c": {
    "id": "t2m_monthly_mean_c",
    "title": "2m temperature monthly mean",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "monthly",
    "source": {
      "type": "cds",
      "dataset_ref": "era5_daily_t2m",
      "batch_tiles_override": 4,
      "agg": "monthly_mean_from_daily",
      "time_range": { "start_year": 1979, "end_year": 2025 }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "t2m_monthly_max_c": {
    "id": "t2m_monthly_max_c",
    "title": "2m temperature monthly maximum",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "monthly",
    "source": {
      "type": "cds",
      "dataset_ref": "era5_daily_t2m_max",
      "batch_tiles_override": 4,
      "agg": "monthly_max_from_daily",
      "time_range": { "start_year": 1979, "end_year": 2025 }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "t2m_monthly_min_c": {
    "id": "t2m_monthly_min_c",
    "title": "2m temperature monthly minimum",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "monthly",
    "source": {
      "type": "cds",
      "dataset_ref": "era5_daily_t2m_min",
      "batch_tiles_override": 4,
      "agg": "monthly_min_from_daily",
      "time_range": { "start_year": 1979, "end_year": 2025 }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "t2m_daily_mean_c": {
    "id": "t2m_daily_mean_c",
    "title": "2m temperature daily mean",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "daily",
    "llm_hidden": true,
    "source": {
      "type": "cds",
      "dataset_ref": "era5_daily_t2m",
      "batch_tiles_override": 4,
      "agg": "identity",
      "params": {
        "daily_statistic": "daily_mean"
      },
      "time_range": { "start_year": 2021, "end_year": 2025 }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "t2m_hotdays_per_year": {
    "id": "t2m_hotdays_per_year",
    "title": "T2m hot days per year",
    "unit": "days",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "yearly",
    "source": {
      "type": "cds",
      "dataset_ref": "era5_daily_t2m",
      "batch_tiles_override": 4,
      "agg": "hot_days_per_year",
      "params": {
        "baseline_years": 10,
        "percentile": 90,
        "daily_statistic": "daily_mean"
      }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "tp_annual_total_mm": {
    "id": "tp_annual_total_mm",
    "title": "Total precipitation yearly sum",
    "unit": "mm",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "yearly",
    "rankings": ["mean", "trend_slope"],
    "aggregates": ["mean"],
    "source": {
      "type": "cds",
      "dataset_ref": "era5_daily_tp",
      "batch_tiles_override": 4,
      "agg": "annual_sum_from_daily",
      "time_range": { "start_year": 1979, "end_year": 2025 }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "tp_cdd_per_year": {
    "id": "tp_cdd_per_year",
    "title": "Maximum consecutive dry days per year",
    "unit": "days",
    "dtype": "float32",
    "missing": "nan",
    "domain": "global",
    "time_axis": "yearly",
    "source": {
      "type": "cds",
      "dataset_ref": "era5_daily_tp",
      "batch_tiles_override": 4,
      "agg": "max_cdd_per_year",
      "params": { "dry_day_threshold_mm": 1.0 },
      "time_range": { "start_year": 1979, "end_year": 2025 }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "sst_yearly_mean_c": {
    "id": "sst_yearly_mean_c",
    "title": "SST yearly mean",
    "unit": "C",
    "dtype": "float32",
    "missing": "nan",
    "domain": "ocean",
    "time_axis": "yearly",
    "aggregates": ["mean"],
    "source": {
      "type": "erddap",
      "dataset_ref": "oisst_sst_v21_daily",
      "agg": "annual_mean_from_daily"
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "sst_hotdays_per_year": {
    "id": "sst_hotdays_per_year",
    "title": "SST hot days per year",
    "unit": "days",
    "dtype": "float32",
    "missing": "nan",
    "domain": "ocean",
    "time_axis": "yearly",
    "source": {
      "type": "erddap",
      "dataset_ref": "oisst_sst_v21_daily",
      "agg": "hot_days_per_year",
      "params": { "baseline_years": 10, "percentile": 90 }
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  },
  "dhw_no_risk_days_per_year": {
    "id": "dhw_no_risk_days_per_year",
    "title": "Coral reef DHW no-risk days per year",
    "unit": "days",
    "dtype": "float32",
    "missing": "nan",
    "domain": "dataset_mask",
    "time_axis": "yearly",
    "llm_note": "Always fetch all three DHW risk-day metrics together (no_risk, moderate_risk, severe_risk) for any location query so the chart shows the full breakdown. Data is indexed by nearest city — use a nearby city name, not a reef name.",
    "source": {
      "type": "erddap",
      "dataset_ref": "crw_dhw_daily",
      "agg": "dhw_no_risk_days_per_year"
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    },
    "chart_group": {
      "id": "dhw_risk_days",
      "chart_mode": "stacked_bar",
      "chart_title": "Coral reef DHW risk days",
      "label": "No risk (DHW < 4)",
      "short_label": "No risk",
      "order": 0,
      "style": { "type": "bar", "color": "#ccccff", "stack": "dhw_risk_days" }
    }
  },
  "dhw_moderate_risk_days_per_year": {
    "id": "dhw_moderate_risk_days_per_year",
    "title": "Coral reef DHW moderate-risk days per year",
    "unit": "days",
    "dtype": "float32",
    "missing": "nan",
    "domain": "dataset_mask",
    "time_axis": "yearly",
    "llm_note": "Always fetch all three DHW risk-day metrics together (no_risk, moderate_risk, severe_risk) for any location query so the chart shows the full breakdown. Data is indexed by nearest city — use a nearby city name, not a reef name.",
    "source": {
      "type": "erddap",
      "dataset_ref": "crw_dhw_daily",
      "agg": "dhw_moderate_risk_days_per_year"
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    },
    "chart_group": {
      "id": "dhw_risk_days",
      "chart_mode": "stacked_bar",
      "chart_title": "Coral reef DHW risk days",
      "label": "Moderate risk (4 \u2264 DHW < 8)",
      "short_label": "Moderate risk",
      "order": 1,
      "style": { "type": "bar", "color": "#fdd835", "stack": "dhw_risk_days" }
    }
  },
  "dhw_severe_risk_days_per_year": {
    "id": "dhw_severe_risk_days_per_year",
    "title": "Coral reef DHW severe-risk days per year",
    "unit": "days",
    "dtype": "float32",
    "missing": "nan",
    "domain": "dataset_mask",
    "time_axis": "yearly",
    "llm_note": "Always fetch all three DHW risk-day metrics together (no_risk, moderate_risk, severe_risk) for any location query so the chart shows the full breakdown. Data is indexed by nearest city — use a nearby city name, not a reef name.",
    "source": {
      "type": "erddap",
      "dataset_ref": "crw_dhw_daily",
      "agg": "dhw_severe_risk_days_per_year"
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    },
    "chart_group": {
      "id": "dhw_risk_days",
      "chart_mode": "stacked_bar",
      "chart_title": "Coral reef DHW risk days",
      "label": "Severe risk (DHW \u2265 8)",
      "short_label": "Severe risk",
      "order": 2,
      "style": { "type": "bar", "color": "#ff0000", "stack": "dhw_risk_days" }
    }
  },
  "dhw_risk_score_per_year": {
    "id": "dhw_risk_score_per_year",
    "title": "Coral reef DHW risk score per year",
    "unit": "score",
    "dtype": "float32",
    "missing": "nan",
    "domain": "dataset_mask",
    "time_axis": "yearly",
    "llm_note": "Combined heat-stress score (weighted sum of risk days). For 'which location has the largest increase in bleaching events', use find_extreme_location with aggregation=trend_slope and extremum=max. Do NOT use get_region_metric_series for this. Data is indexed by nearest city — do not pass reef names.",
    "source": {
      "type": "erddap",
      "dataset_ref": "crw_dhw_daily",
      "agg": "dhw_risk_score_per_year"
    },
    "storage": {
      "tiled": true,
      "compression": { "codec": "zstd", "level": 10 }
    }
  }
}
