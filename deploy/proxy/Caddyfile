# Copy to /etc/caddy/Caddyfile and replace example.com with your domain.
example.com {
  encode gzip zstd

  # Optional local snippets (e.g. beta auth gate).
  import /etc/caddy/conf.d/*.caddy

  # Admin pages: require basic auth before routing.
  # Set ADMIN_USER and ADMIN_PASSWORD_HASH (bcrypt) in the environment.
  # Generate hash with: caddy hash-password
  @admin path /admin* /api/admin/*
  basicauth @admin {
    {$ADMIN_USER} {$ADMIN_PASSWORD_HASH}
  }

  # Basic security headers
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
  }

  # API and map assets routes with timeouts.
  # Request rate limiting is enforced in the backend middleware by default.
  @backend path /api/* /assets/* /healthz
  handle @backend {
    reverse_proxy 127.0.0.1:8001 {
      transport http {
        read_timeout 15s
        write_timeout 15s
      }
      health_uri /healthz
      health_interval 10s
      health_timeout 2s
    }
  }

  # Frontend route
  handle {
    reverse_proxy 127.0.0.1:3000 {
      transport http {
        read_timeout 15s
        write_timeout 15s
      }
    }
  }

  log {
    output file /var/log/caddy/climate-access.log {
      roll_size 10MiB
      roll_keep 10
      roll_keep_for 720h
    }
    format json
  }
}
