  "t2m_trend_score": {
    "id": "t2m_trend_score",
    "title": "Air temperature trend score",
    "type": "score",
    "source_metric": "t2m_yearly_mean_c",
    "reducer": {
      "op": "trend_slope",
      "start_year": 1979,
      "end_year": 2025
    },
    "default_score": 1,
    "score_rules": [
      { "score": 4, "predicate": { "op": "gt", "threshold": 0.04 } },
      { "score": 3, "predicate": { "op": "gt", "threshold": 0.03 } },
      { "score": 2, "predicate": { "op": "gt", "threshold": 0.02 } }
    ],
    "output": {
      "png_filename": "t2m_trend_score.png",
      "binary_filename": "t2m_trend_score.i16.bin",
      "dtype": "int16"
    }
  },
