{
  "version": "0.1",
  "panels": {
    "overview": {
      "title": "Overview",
      "graphs": [
        {
          "id": "t2m_annual",
          "title": "Annual temperature",
          "x_axis_label": "Year",
          "y_axis_label": "Temperature (°C)",
          "caption": { "type": "fn", "fn": "fifty_year_caption", "params": {} },
          "source": "CDS ERA5 2m temperature monthly means (1979-2025)",
          "series": [
            {
              "key": "t2m_yearly_mean",
              "metric": "t2m_yearly_mean_c",
              "label": "Annual mean",
              "unit": "C"
            },
            {
              "key": "t2m_yearly_mean_5y",
              "metric": "t2m_yearly_mean_c",
              "label": "5-year mean",
              "unit": "C",
              "transform": {
                "fn": "rolling_mean",
                "params": { "window": 5, "centered": true }
              },
              "annotations": [
                { "type": "min", "label": "Minimum" },
                { "type": "max", "label": "Maximum" }
              ]
            },
            {
              "key": "t2m_yearly_trend",
              "metric": "t2m_yearly_mean_c",
              "label": "Trend",
              "unit": "C",
              "transform": { "fn": "linear_trend_line" }
            }
          ]
        },
        {
