# Climate API environment variables (copy to /etc/climate/backend.env)
# Adjust paths to your VM deployment location.

API_HOST=127.0.0.1
API_PORT=8001

REPO_ROOT=/opt/climate/source
RELEASE=latest
RELEASES_ROOT=/opt/climate/source/data/releases
LATEST_RELEASE_FILE=/opt/climate/source/data/releases/LATEST
LOCATIONS_CSV=/opt/climate/source/data/locations/locations.csv
LOCATIONS_INDEX_CSV=/opt/climate/source/data/locations/locations.index.csv
KDTREE_PATH=/opt/climate/source/data/locations/locations.kdtree.pkl
OCEAN_MASK_NPZ=/opt/climate/source/data/locations/ocean_mask.npz
OCEAN_NAMES_JSON=/opt/climate/source/data/locations/ocean_names.json

# Cache and preload
REDIS_URL=
TTL_RESOLVE_S=86400
TTL_PANEL_S=86400
SCORE_MAP_PRELOAD=1

# Production CORS: comma-separated origins, no spaces.
# Example: CORS_ALLOW_ORIGINS=https://your-domain.com,https://www.your-domain.com
CORS_ALLOW_ORIGINS=https://example.com
CORS_ALLOW_CREDENTIALS=1
