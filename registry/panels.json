{
  "version": "0.1",
  "layer_overrides": {
    "warming_air": {
      "default_graph_ids": [
        "t2m_annual",
        "t2m_hot_days",
        "sst_annual",
        "sst_hot_days",
        "dhw_risk_days"
      ],
      "title_mode": "recent_trend",
      "title_metric_key": "t2m_recent_local",
      "title_suffix": "since 1979.",
      "title_action_text": "the air has warmed by",
      "title_action_text_non_positive": "the air has not warmed"
    },
    "warming_vs_preindustrial_air": {
      "default_graph_ids": [
        "t2m_annual",
        "t2m_hot_days",
        "sst_annual",
        "sst_hot_days",
        "dhw_risk_days"
      ],
      "title_mode": "preindustrial",
      "title_metric_key": "t2m_vs_preindustrial_local",
      "title_suffix": "since 1850-1900.",
      "title_action_text": "the air has warmed by",
      "title_action_text_non_positive": "the air has not warmed"
    },
    "warming_sst": {
      "default_graph_ids": [
        "sst_annual",
        "sst_hot_days",
        "dhw_risk_days",
        "t2m_annual",
        "t2m_hot_days"
      ],
      "title_mode": "recent_trend",
      "title_metric_key": "sst_recent_local",
      "title_suffix": "since 1982.",
      "title_action_text": "the sea has warmed by",
      "title_action_text_non_positive": "the sea has not warmed"
    },
    "reef_stress": {
      "default_graph_ids": [
        "dhw_risk_days",
        "sst_annual",
        "sst_hot_days",
        "t2m_annual",
        "t2m_hot_days"
      ],
      "title_mode": "recent_trend",
      "title_metric_key": "sst_recent_local",
      "title_suffix": "since 1982.",
      "title_action_text": "the sea has warmed by",
      "title_action_text_non_positive": "the sea has not warmed"
    }
  },
  "panels": {
    "air_temperature": {
      "title": "Air Temperature",
      "score_map_id": "t2m_trend_score",
      "graphs": [
        {
          "id": "t2m_annual",
          "title": "Annual air temperature",
          "ui": {
            "info_text": "Annual air temperature is derived from daily air temperature at 2 meters above the surface, aggregated into monthly and yearly averages for 1979-2025. We show a zoomed-in version of the daily and monthly temperatures over 5 years (2021-2025) that reflects seasonal changes. Source: CDS.",
            "chart_mode": "temperature_line",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Temperature ({unit})",
          "source": "CDS ERA5 2m temperature daily means (2021-2025), aggregated to monthly and yearly means (1979-2025)",
          "animation": {
            "autoplay": false,
            "loop": false,
            "steps": [
              {
                "id": "all_years",
                "title": "Climate",
                "series_keys": [
                  "t2m_yearly_mean",
                  "t2m_yearly_mean_5y",
                  "t2m_yearly_trend"
                ]
              },
              {
                "id": "zoom_in",
                "title": "Seasons",
                "time_range": { "last": { "value": 5, "unit": "years" } },
                "series_keys": [
                  "t2m_daily_mean",
                  "t2m_monthly_mean",
                  "t2m_monthly_trend"
                ]
              }
            ]
          },
          "series": [
            {
              "key": "t2m_daily_mean",
              "metric": "t2m_daily_mean_c",
              "label": "Daily mean",
              "ui": { "role": "raw" },
              "unit": "C",
              "style": { "type": "line", "color": "rgba(180,180,180,0.7)" }
            },
            {
              "key": "t2m_monthly_mean",
              "metric": "t2m_monthly_mean_c",
              "label": "Monthly mean",
              "ui": { "role": "mean" },
              "unit": "C",
              "style": { "type": "line", "color": "#1736ff" }
            },
            {
              "key": "t2m_yearly_mean",
              "metric": "t2m_yearly_mean_c",
              "label": "Annual mean",
              "ui": { "role": "raw" },
              "unit": "C",
              "style": { "type": "line", "color": "#ff2e55" }
            },
            {
              "key": "t2m_yearly_mean_5y",
              "metric": "t2m_yearly_mean_c",
              "label": "5-year mean",
              "ui": { "role": "mean" },
              "unit": "C",
              "style": { "type": "line", "color": "#1736ff" },
              "transform": {
                "fn": "rolling_mean",
                "params": { "window": 5, "centered": true }
              },
              "annotations": [
                { "type": "min", "label": "Minimum" },
                { "type": "max", "label": "Maximum" }
              ]
            },
            {
              "key": "t2m_yearly_trend",
              "metric": "t2m_yearly_mean_c",
              "label": "Trend",
              "ui": { "role": "trend" },
              "unit": "C",
              "style": { "type": "line", "color": "rgba(255,0,0,0.24)" },
              "transform": { "fn": "linear_trend_line" }
            },
            {
              "key": "t2m_monthly_trend",
              "metric": "t2m_monthly_mean_c",
              "label": "Trend",
              "ui": { "role": "trend" },
              "unit": "C",
              "style": { "type": "line", "color": "rgba(255,0,0,0.24)" },
              "transform": {
                "fn": "linear_trend_line",
                "params": { "extend_to": "2025-12-31" }
              }
            }
          ]
        },
        {
          "id": "t2m_hot_days",
          "title": "Number of hot days",
          "ui": {
            "info_text": "Number of hot days per year are counted as days warmer than the top 10% warmest days in a 10-year baseline starting in 1979, for 1979-2025. Source: CDS.",
            "chart_mode": "hot_days_combo",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Days/year",
          "source": "CDS ERA5 2m temperature daily means (1979-2025)",
          "series": [
            {
              "key": "t2m_hotdays",
              "metric": "t2m_hotdays_per_year",
              "label": "Hot days",
              "ui": { "role": "raw" },
              "unit": "days",
              "style": { "type": "bar", "color": "#ccccff" }
            },
            {
              "key": "t2m_hotdays_5y",
              "metric": "t2m_hotdays_per_year",
              "label": "5-year mean",
              "ui": { "role": "mean" },
              "unit": "days",
              "style": { "type": "line", "color": "#1736ff" },
              "transform": {
                "fn": "rolling_mean",
                "params": { "window": 5, "centered": true }
              }
            },
            {
              "key": "t2m_hotdays_trend",
              "metric": "t2m_hotdays_per_year",
              "label": "Trend",
              "ui": { "role": "trend" },
              "unit": "days",
              "style": { "type": "line", "color": "rgba(255,0,0,0.24)" },
              "transform": { "fn": "linear_trend_line" }
            }
          ]
        }
      ]
    },
    "sea_temperature": {
      "title": "Sea Surface Temperature",
      "score_map_id": "sst_trend_score",
      "graphs": [
        {
          "id": "sst_annual",
          "title": "Annual sea surface temperature",
          "ui": {
            "info_text": "Annual sea surface temperature is derived from daily sea surface temperature, aggregated into yearly averages for 1982-2025. Source: ERDDAP.",
            "chart_mode": "temperature_line",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Temperature ({unit})",
          "source": "ERDDAP OISST v2.1 daily sea surface temperature (1982-2025), aggregated to yearly means",
          "series": [
            {
              "key": "sst_yearly_mean",
              "metric": "sst_yearly_mean_c",
              "label": "Annual mean",
              "ui": { "role": "raw" },
              "unit": "C",
              "style": { "type": "line", "color": "#ff2e55" }
            },
            {
              "key": "sst_yearly_mean_5y",
              "metric": "sst_yearly_mean_c",
              "label": "5-year mean",
              "ui": { "role": "mean" },
              "unit": "C",
              "style": { "type": "line", "color": "#1736ff" },
              "transform": {
                "fn": "rolling_mean",
                "params": { "window": 5, "centered": true }
              },
              "annotations": [
                { "type": "min", "label": "Minimum" },
                { "type": "max", "label": "Maximum" }
              ]
            },
            {
              "key": "sst_yearly_trend",
              "metric": "sst_yearly_mean_c",
              "label": "Trend",
              "ui": { "role": "trend" },
              "unit": "C",
              "style": { "type": "line", "color": "rgba(255,0,0,0.24)" },
              "transform": { "fn": "linear_trend_line" }
            }
          ]
        },
        {
          "id": "sst_hot_days",
          "title": "Number of sea surface hot days",
          "ui": {
            "info_text": "Number of sea surface hot days per year are counted as days where the sea surface temperature is warmer than the top 10% warmest days in a 10-year baseline starting in 1982, for 1982-2025. Source: ERDDAP.",
            "chart_mode": "hot_days_combo",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Days/year",
          "source": "ERDDAP OISST v2.1 daily sea surface temperature (1982-2025)",
          "series": [
            {
              "key": "sst_hotdays",
              "metric": "sst_hotdays_per_year",
              "label": "Hot days",
              "ui": { "role": "raw" },
              "unit": "days",
              "style": { "type": "bar", "color": "#ccccff" }
            },
            {
              "key": "sst_hotdays_5y",
              "metric": "sst_hotdays_per_year",
              "label": "5-year mean",
              "ui": { "role": "mean" },
              "unit": "days",
              "style": { "type": "line", "color": "#1736ff" },
              "transform": {
                "fn": "rolling_mean",
                "params": { "window": 5, "centered": true }
              }
            },
            {
              "key": "sst_hotdays_trend",
              "metric": "sst_hotdays_per_year",
              "label": "Trend",
              "ui": { "role": "trend" },
              "unit": "days",
              "style": { "type": "line", "color": "rgba(255,0,0,0.24)" },
              "transform": { "fn": "linear_trend_line" }
            }
          ]
        }
      ]
    },
    "precipitation":     {
      "title": "Precipitation",
      "score_map_id": "tp_annual_trend_score",
      "graphs": [
        {
          "id": "tp_annual",
          "title": "Annual total precipitation",
          "ui": {
            "info_text": "Annual total precipitation is derived from daily ERA5 total precipitation, summed into yearly totals for 1979-2025. Source: CDS.",
            "chart_mode": "temperature_line",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Precipitation (mm)",
          "source": "CDS ERA5 daily total precipitation (1979-2025), aggregated to yearly sums",
          "series": [
            {
              "key": "tp_yearly_total",
              "metric": "tp_annual_total_mm",
              "label": "Annual total",
              "ui": {
                "role": "raw"
              },
              "unit": "mm",
              "style": {
                "type": "line",
                "color": "#1f77b4"
              }
            },
            {
              "key": "tp_yearly_total_5y",
              "metric": "tp_annual_total_mm",
              "label": "5-year mean",
              "ui": {
                "role": "mean"
              },
              "unit": "mm",
              "style": {
                "type": "line",
                "color": "#1736ff"
              },
              "transform": {
                "fn": "rolling_mean",
                "params": {
                  "window": 5,
                  "centered": true
                }
              },
              "annotations": [
                {
                  "type": "min",
                  "label": "Minimum"
                },
                {
                  "type": "max",
                  "label": "Maximum"
                }
              ]
            },
            {
              "key": "tp_yearly_trend",
              "metric": "tp_annual_total_mm",
              "label": "Trend",
              "ui": {
                "role": "trend"
              },
              "unit": "mm",
              "style": {
                "type": "line",
                "color": "rgba(255,0,0,0.24)"
              },
              "transform": {
                "fn": "linear_trend_line"
              }
            }
          ]
        },
        {
          "id": "tp_cdd",
          "title": "Consecutive dry days",
          "ui": {
            "info_text": "Maximum number of consecutive dry days (daily precipitation < 1 mm) per year for 1979-2025. Source: CDS.",
            "chart_mode": "hot_days_combo",
            "axis_title_mode": "year"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Days/year",
          "source": "CDS ERA5 daily total precipitation (1979-2025)",
          "series": [
            {
              "key": "tp_cdd",
              "metric": "tp_cdd_per_year",
              "label": "Max dry spell",
              "ui": {
                "role": "raw"
              },
              "unit": "days",
              "style": {
                "type": "bar",
                "color": "#f4a582"
              }
            },
            {
              "key": "tp_cdd_5y",
              "metric": "tp_cdd_per_year",
              "label": "5-year mean",
              "ui": {
                "role": "mean"
              },
              "unit": "days",
              "style": {
                "type": "line",
                "color": "#1736ff"
              },
              "transform": {
                "fn": "rolling_mean",
                "params": {
                  "window": 5,
                  "centered": true
                }
              }
            },
            {
              "key": "tp_cdd_trend",
              "metric": "tp_cdd_per_year",
              "label": "Trend",
              "ui": {
                "role": "trend"
              },
              "unit": "days",
              "style": {
                "type": "line",
                "color": "rgba(255,0,0,0.24)"
              },
              "transform": {
                "fn": "linear_trend_line"
              }
            }
          ]
        },
        {
          "id": "tp_wet_days",
          "title": "Wet days per year",
          "ui": {
            "info_text": "Number of days per year with at least 1 mm of precipitation. A declining count indicates drying conditions. Source: CDS ERA5.",
            "chart_mode": "hot_days_combo",
            "axis_title_mode": "year",
            "trend_unit": "days"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Days/year",
          "source": "CDS ERA5 daily total precipitation (1979-2025)",
          "series": [
            {
              "key": "tp_wet_days",
              "metric": "tp_wet_days_per_year",
              "label": "Wet days",
              "ui": {
                "role": "raw"
              },
              "unit": "days",
              "style": {
                "type": "bar",
                "color": "#67a9cf"
              }
            },
            {
              "key": "tp_wet_days_5y",
              "metric": "tp_wet_days_per_year",
              "label": "5-year mean",
              "ui": {
                "role": "mean"
              },
              "unit": "days",
              "style": {
                "type": "line",
                "color": "#2166ac"
              },
              "transform": {
                "fn": "rolling_mean",
                "params": {
                  "window": 5,
                  "centered": true
                }
              }
            },
            {
              "key": "tp_wet_days_trend",
              "metric": "tp_wet_days_per_year",
              "label": "Trend",
              "ui": {
                "role": "trend"
              },
              "unit": "days",
              "style": {
                "type": "line",
                "color": "rgba(255,0,0,0.24)"
              },
              "transform": {
                "fn": "linear_trend_line"
              }
            }
          ]
        },
        {
          "id": "tp_rx5day",
          "title": "Max 5-day precipitation",
          "ui": {
            "info_text": "Maximum 5-day consecutive precipitation total per year (Rx5day). An increasing trend indicates intensifying extreme rainfall events. Source: CDS ERA5.",
            "chart_mode": "temperature_line",
            "axis_title_mode": "year",
            "trend_unit": "mm"
          },
          "x_axis_label": "Year",
          "y_axis_label": "Precipitation (mm)",
          "source": "CDS ERA5 daily total precipitation (1979-2025)",
          "series": [
            {
              "key": "tp_rx5day",
              "metric": "tp_rx5day_per_year",
              "label": "Rx5day",
              "ui": {
                "role": "raw"
              },
              "unit": "mm",
              "style": {
                "type": "line",
                "color": "#1f77b4"
              }
            },
            {
              "key": "tp_rx5day_5y",
              "metric": "tp_rx5day_per_year",
              "label": "5-year mean",
              "ui": {
                "role": "mean"
              },
              "unit": "mm",
              "style": {
                "type": "line",
                "color": "#2166ac"
              },
              "transform": {
                "fn": "rolling_mean",
                "params": {
                  "window": 5,
                  "centered": true
                }
              },
              "annotations": [
                {
                  "type": "min",
                  "label": "Minimum"
                },
                {
                  "type": "max",
                  "label": "Maximum"
                }
              ]
            },
            {
              "key": "tp_rx5day_trend",
